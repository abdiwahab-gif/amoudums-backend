# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=academic_db

# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
