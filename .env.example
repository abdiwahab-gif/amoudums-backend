# Database Configuration
# Railway / hosted MySQL (preferred on Render):
# MYSQL_PUBLIC_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE
# (If you set MYSQL_PUBLIC_URL, the DB_* vars below are optional.)
MYSQL_PUBLIC_URL=

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=academic_db

# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Startup behavior
# By default, the server runs idempotent migrations on startup.
# Set to "false" only if you run migrations separately (e.g. a release job).
RUN_MIGRATIONS_ON_STARTUP=true

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d

# Optional: initial admin user seeding (runs once if user doesn't exist)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_FIRST_NAME=Admin
INITIAL_ADMIN_LAST_NAME=User

# CORS Configuration
# Comma-separated allowlist of frontend origins.
# Examples:
#   CORS_ORIGIN=http://localhost:3000
#   CORS_ORIGIN=https://amoudums.vercel.app,http://localhost:3000
# Defaults always allowed (even if you don't set CORS_ORIGIN):
#   - https://amoudums.vercel.app
#   - http://localhost:3000
# Use CORS_ORIGIN to add additional origins if needed.
CORS_ORIGIN=http://localhost:3000

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Logging
LOG_LEVEL=debug
